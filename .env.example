# OpenMagic configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for LLM access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Composio API key and Gmail auth config ID
# Get these from https://composio.dev/
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_GMAIL_AUTH_CONFIG_ID=your_gmail_auth_config_id_here
# Required for deterministic Workflow sends. This trusted Composio user ID
# must identify the connected mailbox represented by the Broker email below.
OPENMAGIC_WORKFLOW_COMPOSIO_USER_ID=your_composio_user_id_here
# Required only for the opt-in live Gmail acceptance test.
OPENMAGIC_LIVE_EMAIL_SENDER=your_connected_sender@example.com
OPENMAGIC_LIVE_EMAIL_RECIPIENT=your_disposable_recipient@example.com
AGENTMAIL_API_KEY=your_agentmail_api_key_here

# Required for the durable Workflow Control Plane
OPENMAGIC_DATABASE_URL=postgresql+psycopg://openmagic:openmagic@localhost:5432/openmagic
OPENMAGIC_WORKFLOW_CURSOR_SECRET=replace_with_a_random_local_secret
OPENMAGIC_WORKFLOW_BROKER_PARTY_ID=10000000-0000-0000-0000-000000000001
OPENMAGIC_WORKFLOW_ORGANIZATION_PARTY_ID=20000000-0000-0000-0000-000000000001
# V0 Browser Basic Auth password (username: openmagic).
OPENMAGIC_BROWSER_PASSWORD=replace_with_a_random_local_browser_password
# Server-only credential used by the trusted Next.js proxy.
OPENMAGIC_WORKFLOW_INTERACTION_TOKEN=replace_with_a_random_local_interaction_secret

# Use legacy only for controlled comparison with inherited named-agent delegation
OPENMAGIC_INTERACTION_MODE=workflow

# Optional: Server configuration
# OPENPOKE_HOST=0.0.0.0
# OPENPOKE_PORT=8001

# Optional: CORS configuration
# OPENPOKE_CORS_ALLOW_ORIGINS=*

# Optional: Documentation
# OPENPOKE_ENABLE_DOCS=1
# OPENPOKE_DOCS_URL=/docs
